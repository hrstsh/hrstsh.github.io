---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { triedPosts } from '../../data/tried';
import { itemList } from '../../utils/jsonLd';

const items = triedPosts.map((p) => ({ name: p.title, url: p.href }));
const jsonLd = itemList('やってみた', '実際に試したことの手記やレポート。GitHub Pages の立ち上げ、カスタムドメイン設定など。', 'https://hrstsh.com/tried', items);
---

<ArticleLayout title="やってみた - hrの備忘録" description="実際に試したことの手記やレポート。GitHub Pages の立ち上げ、カスタムドメイン設定など。" jsonLd={jsonLd} currentTags={[]}>
    <header class="page-header">
      <h1>やってみた</h1>
      <p class="subtitle">実際に試したことの手記やレポート</p>
    </header>

    <section class="intro-section">
      <p>
        自分が欲しくて作ったもの・試したことの記録。つまずいた箇所や、なぜその方法にしたかもなるべく残すようにした。
      </p>
    </section>

    <ul class="post-list">
      {triedPosts.map((post) => (
        <li>
          <a class="post-row" href={post.href}>
            <span class="post-main">
              <span class="post-title">{post.title}</span>
              <span class="post-desc">{post.desc}</span>
            </span>
            <time class="post-date">{post.date}</time>
          </a>
        </li>
      ))}
    </ul>

    <footer class="page-footer">
      <a href="/">トップに戻る</a>
    </footer>
</ArticleLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    color: var(--color-text);
  }

  .subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .intro-section {
    margin-bottom: 2.5rem;
  }

  .intro-section p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .intro-section p:last-child {
    margin-bottom: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 0.75rem;
    margin-inline: -0.75rem;
    border-bottom: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast);
  }

  .post-row:hover {
    background: rgba(var(--accent-rgb), 0.04);
  }

  .post-main {
    min-width: 0;
  }

  .post-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.7;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .post-row:hover .post-title {
    color: var(--color-primary);
  }

  .post-desc {
    display: block;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-top: 0.55rem;
  }

  .post-date {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.85;
    padding-top: 0.3rem;
  }

  .page-footer {
    margin-top: 2.5rem;
    text-align: center;
  }

  .page-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .page-footer a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 599px) {
    h1 {
      font-size: 1.4rem;
      margin-bottom: 0.2rem;
    }

    .subtitle {
      font-size: 0.85rem;
    }

    .page-header {
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
    }

    .intro-section {
      margin-bottom: 1.5rem;
    }

    .intro-section p {
      font-size: 0.85rem;
      line-height: 1.65;
      margin-bottom: 0.6rem;
    }

    .post-row {
      padding: 0.75rem 0.5rem;
      margin-inline: -0.5rem;
      gap: 1rem;
    }

    .post-title {
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .post-desc {
      font-size: 0.8rem;
      line-height: 1.6;
      margin-top: 0.3rem;
    }

    .post-date {
      font-size: 0.72rem;
      padding-top: 0.15rem;
    }
  }
</style>
