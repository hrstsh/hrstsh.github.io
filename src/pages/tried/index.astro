---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { triedPosts } from '../../data/tried';
import { itemList } from '../../utils/jsonLd';

const items = triedPosts.map((p) => ({ name: p.title, url: p.href }));
const jsonLd = itemList('やってみた', '実際に試したことの手記やレポート。GitHub Pages の立ち上げ、カスタムドメイン設定など。', 'https://hrstsh.com/tried', items);
---

<ArticleLayout title="やってみた - hrの備忘録" description="実際に試したことの手記やレポート。GitHub Pages の立ち上げ、カスタムドメイン設定など。" jsonLd={jsonLd} currentTags={[]}>
    <header class="page-header">
      <h1>やってみた</h1>
      <p class="subtitle">実際に試したことの手記やレポート</p>
    </header>

    <section class="intro-section">
      <p>
        作ってみた・試してみたことの記録です。Chrome 拡張、Telegram Bot、ローカルの音声合成基盤、GA4 データの自動取得など、自分が欲しくて手を動かしたものを一人称でまとめています。
      </p>
      <p>
        うまくいった部分だけでなく、つまずいた箇所や、その方法を選んだ理由もできるだけ残すようにしました。同じことをやろうとしている人が、回り道を1つでも減らせれば十分です。
      </p>
    </section>

    <ul class="post-list">
      {triedPosts.map((post) => (
        <li>
          <a class="post-row" href={post.href}>
            <span class="post-main">
              <span class="post-title">{post.title}</span>
              <span class="post-desc">{post.desc}</span>
            </span>
            <time class="post-date">{post.date}</time>
          </a>
        </li>
      ))}
    </ul>

    <footer class="page-footer">
      <a href="/">トップに戻る</a>
    </footer>
</ArticleLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border-bottom: none;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-primary);
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    color: var(--color-text);
  }

  .subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .intro-section {
    margin-bottom: 2.5rem;
  }

  .intro-section p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .intro-section p:last-child {
    margin-bottom: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--color-border-card);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-normal), border-color var(--transition-normal), transform var(--transition-normal);
  }

  .post-row:hover {
    box-shadow: var(--shadow-card-hover);
    border-color: rgba(102, 126, 234, 0.18);
    transform: translateY(-1px);
  }

  .post-main {
    min-width: 0;
  }

  .post-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.7;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .post-row:hover .post-title {
    color: var(--color-primary);
  }

  .post-desc {
    display: block;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-top: 0.35rem;
  }

  .post-date {
    flex-shrink: 0;
    font-family: 'Source Code Pro', ui-monospace, 'SFMono-Regular', monospace;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.85;
    padding-top: 0.3rem;
  }

  .page-footer {
    margin-top: 2.5rem;
    text-align: center;
  }

  .page-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .page-footer a:hover {
    color: var(--color-accent);
  }
</style>
