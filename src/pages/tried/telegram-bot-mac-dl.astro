---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooterNav from '../../components/ArticleFooterNav.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import { tipArticle, toIsoDate } from '../../utils/jsonLd';

const title = '外出先から自宅の Mac を操作する Telegram Bot を作ってみた - hrの備忘録';
const description = '外出先のスマートフォンから自宅の Mac を操作する Telegram Bot。yt-dlp で YouTube 動画・音声をダウンロードする bot を構築した手記。';
const jsonLd = tipArticle(title.replace(/ - hrの備忘録$/, ''), description, '/tried/telegram-bot-mac-dl', toIsoDate('2026.03'), 'tried');

const projectStructure = `bot/
├── main.py           # エントリポイント・ハンドラ登録
├── config.py         # 環境変数・設定
├── handlers/
│   ├── dl_handler.py    # /dl コマンド
│   ├── help_handler.py # /help
│   ├── status_handler.py # /status
│   └── ...
└── commands/
    ├── dl_dispatch.py   # URL 判定とプラットフォーム振り分け
    ├── dl_youtube.py   # yt-dlp による YouTube 動画・音声
    ├── dl_twitter.py   # Twitter 動画
    ├── dl_common.py    # シグナルハンドラ・サブプロセス終了
    └── dl_state.py     # 実行中タスクの状態管理`;

const ydlOptsVideo = `ydl_opts = {
    "format": "bestvideo+bestaudio/best",
    "merge_output_format": "mp4",
    "outtmpl": str(DL_OUTPUT_DIR / "%(id)s.%(ext)s"),
    "restrictfilenames": True,  # パストラバーサル対策
    "quiet": True,
    "no_warnings": True,
}
if live_stream:
    ydl_opts["live_from_start"] = True`;

const dlHandlerThread = `# ブロッキング処理を別スレッドで実行
download_id = register_download(url, media_type, live_stream, user_id)
try:
    success, message = await asyncio.to_thread(
        download, url, audio_only, live_stream
    )
    await update.message.reply_text(message)
finally:
    unregister_download(download_id)`;

const dlDispatch = `def download(url, audio_only, live_stream) -> tuple[bool, str]:
    if dl_youtube.is_youtube_url(url):
        if audio_only:
            return dl_youtube.download_audio(url, live_stream=live_stream)
        return dl_youtube.download_video(url, live_stream=live_stream)
    if dl_twitter.is_twitter_url(url):
        return dl_twitter.download_video(url)
    return False, "対応していない URL です。"`;

const dlCommonSignal = `# Ctrl+C 等で Bot 終了時にサブプロセスを確実に終了
def _terminate_active_subprocesses():
    for proc in _active_ytdlp_processes:
        if proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                proc.kill()

signal.signal(signal.SIGINT, _signal_handler)
atexit.register(_terminate_active_subprocesses)`;

const configAllowed = `# 許可するユーザー ID のリスト（カンマ区切り）
_raw_ids = os.getenv("ALLOWED_USER_IDS", "").strip()
ALLOWED_USER_IDS = [int(uid.strip()) for uid in _raw_ids.split(",") if uid.strip()]`;

const currentTags = ['macos', 'automation'];
---

<ArticleLayout title={title} description={description} jsonLd={jsonLd} currentTags={currentTags} noindex={true}>
    <header class="article-header">
      <a href="/tried/" class="back-link">← やってみた一覧</a>
      <h1>外出先から自宅の Mac を操作する Telegram Bot を作ってみた</h1>
      <p class="article-meta">スマホから自宅の Mac を操作する基盤を Telegram Bot で構築し、例として yt-dlp で動画ダウンロードを実装した</p>
      <p class="article-date">2026.03</p>
    </header>

    <article class="article-body">
      <p>
        外出先から自宅の Mac に処理をさせたいことがあっても、ローカルネットワークの外からは直接触れません。ポートを開けて外部に公開するのは管理が大変なので、Telegram Bot を中継役にして、スマホから送ったメッセージで Mac 側の処理を動かす形にしました。Mac 側は Telegram に接続しにいくだけなので、外向きにポートを開けずに使えるのが利点です。
      </p>
      <p>
        最初の用途として、手元の <code>yt-dlp</code> を呼び出して自分用に動画や音声を取り込む処理を例に実装しました。主眼はあくまで遠隔実行の仕組みづくりで、取得は各サービスの規約と著作権の範囲内で行う前提です。
      </p>

      <h2>構成</h2>
      <p>
        構成はこんな感じです。ハンドラとコマンド実行ロジックを分けて、あとから機能を足しやすくしています。
      </p>
      <CodeBlock code={projectStructure} language="text" />

      <h2>実装例: yt-dlp の呼び出し</h2>
      <p>
        遠隔実行のサンプルとして、受け取った URL を <code>yt-dlp</code> に渡す処理を作りました。<code>/dl</code> は <code>-s</code> で音声のみ、<code>-l</code> でライブ配信を指定できます。URL の種類で処理を振り分けるところは <code>dl_dispatch.py</code> にまとめています。ここで見たいのは、外部コマンドをどう非同期で安全に呼ぶかという部分です。
      </p>
      <CodeBlock code={dlDispatch} language="python" />

      <p>
        yt-dlp はブロッキングなので、<code>asyncio.to_thread</code> で別スレッドに任せて、ダウンロード中も他のリクエストを処理できるようにしました。
      </p>
      <CodeBlock code={dlHandlerThread} language="python" />

      <p>
        動画は最高画質・音声をマージして mp4 で出す設定です。ライブ配信の場合は <code>live_from_start</code> で配信終了まで録画します。
      </p>
      <CodeBlock code={ydlOptsVideo} language="python" />

      <p>
        ファイル名は <code>restrictfilenames</code> でサニタイズしてパストラバーサル対策を入れました。Bot 終了時（Ctrl+C など）に実行中の yt-dlp をちゃんと止めるため、シグナルハンドラと <code>atexit</code> を登録しています。登録済みのサブプロセスを一括で terminate し、5 秒待っても終わらなければ kill する形にしました。
      </p>
      <CodeBlock code={dlCommonSignal} language="python" />

      <h2>セキュリティとコマンド</h2>
      <p>
        ユーザー ID のホワイトリスト（<code>ALLOWED_USER_IDS</code>）で許可した人だけがコマンドを打てるようにしています。<code>.env</code> でカンマ区切りで指定し、<code>/whoami</code> で自分の ID を確認してから追加する運用にしました。
      </p>
      <CodeBlock code={configAllowed} language="python" />

      <p>
        YouTube と Twitter の URL だけ受け付け、他サイトは弾くようにしました。技術スタックは <code>python-telegram-bot</code>、<code>yt-dlp</code>、<code>python-dotenv</code> です。
      </p>

      <p>
        使えるコマンドは <code>/dl</code>（動画・音声・ライブ）、<code>/status</code>、<code>/help</code>、<code>/whoami</code> です。Phase 1 として動く Bot ができたので、今後は Mac 上だからこそできる処理（ローカル LLM、音声の文字起こし、画像・動画の解析など）を足していく予定です。
      </p>

      <h2>利用上の注意</h2>
      <p>
        <code>yt-dlp</code> での取得は、各サービスの利用規約と著作権の範囲内で行います。サービスによっては許可されていない取得方法があり、その判断は利用者の責任になります。自分がアップロードした動画や、権利者から許諾を得たもの、私的な利用の範囲にとどめ、再配布や商用利用はしません。この記事は遠隔実行の仕組みを記録したもので、特定サービスからのダウンロードを推奨する趣旨ではありません。
      </p>
    </article>

    <ArticleFooterNav currentHref="/tried/telegram-bot-mac-dl/" currentTags={currentTags} backHref="/tried/" backLabel="← やってみた一覧に戻る" />
</ArticleLayout>

