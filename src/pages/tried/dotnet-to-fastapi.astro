const lifespanPy = `from contextlib import asynccontextmanager
from fastapi import FastAPI

@asynccontextmanager
async def lifespan(app: FastAPI):
    # 起動時の初期化処理（DB マイグレーションなど）
    print("アプリケーション起動")
    yield
    # 終了時のクリーンアップ
    print("アプリケーション終了")

app = FastAPI(title="My App", lifespan=lifespan)`;

