---
import ArticleLayout from '../layouts/ArticleLayout.astro';
import { triedPosts } from '../data/tried';
import { tipPosts } from '../data/tips';
import { toolEntries } from '../data/tools';
import { webSite, organization } from '../utils/jsonLd';

const siteName = 'hrの備忘録';
const siteDesc = '開発と日常の作業メモ。やってみたこと・Tips・ブラウザで動くツールをまとめています。';
const jsonLd = [webSite(siteName, siteDesc), organization(siteName)];

const tips = tipPosts.slice(0, 6);

const tools = toolEntries.map(t => ({ name: t.shortName, href: t.href }));
---

<ArticleLayout title={siteName} description={siteDesc} jsonLd={jsonLd} currentTags={[]}>
    <header class="masthead">
      <h1>hrの備忘録</h1>
      <p class="tagline">開発と日常の作業メモ</p>
      <p class="lead">
        調べたこと・作ったものを、あとから見返せるように書き残している。
      </p>
    </header>

    <section class="feed">
      <div class="section-head">
        <span class="section-label">やってみた</span>
        <a class="section-more" href="/tried/">すべて見る →</a>
      </div>
      <ul class="post-list">
        {triedPosts.map((post) => (
          <li>
            <a class="post-row" href={post.href}>
              <span class="post-main">
                <span class="post-title">{post.title}</span>
                <span class="post-desc">{post.desc}</span>
              </span>
              <time class="post-date">{post.date}</time>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="feed">
      <div class="section-head">
        <span class="section-label">Tips</span>
        <a class="section-more" href="/tips/">すべて見る →</a>
      </div>
      <ul class="post-list">
        {tips.map((post) => (
          <li>
            <a class="post-row" href={post.href}>
              <span class="post-main">
                <span class="post-title">{post.title}</span>
                <span class="post-desc">{post.desc}</span>
              </span>
              <time class="post-date">{post.date}</time>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="utility">
      <div class="utility-group">
        <div class="section-head">
          <span class="section-label">ツール</span>
          <a class="section-more" href="/tools/">一覧 →</a>
        </div>
        <div class="pill-row">
          {tools.map((t) => (
            <a class="pill" href={t.href}>{t.name}</a>
          ))}
        </div>
      </div>
    </section>
</ArticleLayout>

<style>
  .masthead {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.15rem;
    margin-bottom: 3.5rem;
  }

  .masthead h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin: 0;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0.4rem 0 0;
  }

  .lead {
    font-size: 1rem;
    line-height: 1.95;
    color: var(--color-text-muted);
    margin: 1.25rem 0 0;
    max-width: 60ch;
  }

  .feed {
    margin-bottom: 3.5rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }

  .section-more {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .section-more:hover {
    color: var(--color-primary);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 0.75rem;
    margin-inline: -0.75rem;
    border-bottom: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast);
  }

  .post-row:hover {
    background: rgba(var(--accent-rgb), 0.04);
  }

  .post-main {
    min-width: 0;
  }

  .post-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.7;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .post-row:hover .post-title {
    color: var(--color-primary);
  }

  .post-desc {
    display: block;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-top: 0.55rem;
  }

  .post-date {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.85;
    padding-top: 0.3rem;
  }

  .utility {
    margin-top: 3.25rem;
    padding-top: 0.5rem;
    display: grid;
    gap: 1.75rem;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .pill {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.7rem;
    background: var(--color-bg-card);
    transition: color var(--transition-fast), border-color var(--transition-fast),
      background var(--transition-fast), transform var(--transition-fast);
  }

  .pill:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(var(--accent-rgb), 0.04);
  }

  .pill:active {
    transform: scale(0.97);
  }

  @media (max-width: 599px) {
    .masthead {
      margin-bottom: 1.75rem;
    }

    .masthead h1 {
      font-size: 1.4rem;
    }

    .tagline {
      font-size: 0.8rem;
      margin-top: 0.25rem;
    }

    .lead {
      font-size: 0.85rem;
      line-height: 1.7;
      margin-top: 0.75rem;
    }

    .feed {
      margin-bottom: 2rem;
    }

    .section-head {
      padding-bottom: 0.4rem;
      margin-bottom: 0.25rem;
    }

    .section-label {
      font-size: 0.8rem;
    }

    .post-row {
      padding: 0.75rem 0.5rem;
      margin-inline: -0.5rem;
      gap: 1rem;
    }

    .post-title {
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .post-desc {
      font-size: 0.8rem;
      line-height: 1.6;
      margin-top: 0.3rem;
    }

    .post-date {
      font-size: 0.72rem;
      padding-top: 0.15rem;
    }

    .utility {
      margin-top: 1.75rem;
    }

    .pill {
      font-size: 0.8rem;
      padding: 0.25rem 0.6rem;
    }

    .pill-row {
      margin-top: 0.5rem;
    }
  }

  @media (min-width: 600px) {
    .utility {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
</style>
