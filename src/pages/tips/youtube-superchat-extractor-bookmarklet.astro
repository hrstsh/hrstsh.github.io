  }

  .faq-list dt {
    font-weight: 600;
    margin-top: 1rem;
    margin-bottom: 0.25rem;
    color: #333;
  }
  .faq-list dd {
    margin-left: 0;
    margin-bottom: 0.5rem;
    color: #444;
    line-height: 1.6;
  }
</style>
