---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import ArticleFooterNav from '../../../components/ArticleFooterNav.astro';
import { webApplication, faqPage } from '../../../utils/jsonLd';

const title = 'X（Twitter）検索ツール - 画像・ユーザー・期間で絞り込み | hrの備忘録';
const description = 'X で画像付きツイートや特定ユーザーの投稿を簡単に検索。無料・登録不要・ブラウザで完結。検索コマンドを覚えなくても、フォーム操作だけで高度な検索が可能です。';
const jsonLd = [
  webApplication('X（Twitter）検索ツール', description, 'https://hrstsh.com/tools/x-search-builder/'),
  faqPage(
    [
      { question: 'X で画像付きツイートだけを検索する方法は？', answer: 'このツールで「メディア・フィルター」を展開し「画像」にチェックを入れて検索を実行すると、画像付きのツイートのみが表示されます。' },
      { question: 'X で特定のユーザーの投稿だけを検索する方法は？', answer: '「ユーザー・ハッシュタグ」を展開し、from 欄にユーザー名を入力して検索を実行すると、そのユーザーの投稿のみが表示されます。' },
      { question: 'X の検索ツールは無料ですか？', answer: 'はい、無料です。ブラウザ上で動作し、データの送信も行いません。' },
    ],
    'https://hrstsh.com/tools/x-search-builder/'
  ),
];

const currentTags = ['twitter'];
---

<ArticleLayout title={title} description={description} jsonLd={jsonLd} currentTags={currentTags}>
    <header class="article-header">
      <a href="/tools/" class="back-link">← ツール一覧</a>
      <h1>X（Twitter）検索ツール</h1>
    </header>

    <article class="article-body">
      <p>画像付きツイートだけ検索したい、特定の人の投稿を探したい…そんなときに使えるツールです。検索コマンドを覚えなくても、フォーム操作だけで高度な検索ができます。</p>

      <div class="tool-container">
        <section class="tool-section">
          <div class="keyword-header">
            <h2>キーワード</h2>
            <button type="button" class="info-btn" aria-label="キーワード形式について" id="keywordInfoBtn" aria-expanded="false" aria-haspopup="true">
              <span aria-hidden="true">i</span>
            </button>
            <div id="keywordInfoTooltip" class="info-tooltip" role="tooltip" hidden>
              2026年3月現在、X のキーワード一致検索が行えない状態のため、暫定対応として <code>&#34;&#34;&#34;語句&#34;&#34;&#34;</code> 形式で出力しています。
            </div>
          </div>
          <div id="keywordInputs" class="keyword-inputs">
            <div class="keyword-row">
              <input type="text" class="keyword-input" data-keyword placeholder="検索語句" />
            </div>
          </div>
          <button type="button" id="addKeywordBtn" class="add-btn">+ キーワード追加</button>
        </section>

        <section class="tool-section exclude-section" id="excludeSection" hidden>
          <label class="input-label">除外する語句</label>
          <div id="excludeInputs" class="exclude-inputs"></div>
        </section>
        <button type="button" id="addExcludeBtn" class="add-btn add-exclude-btn">+ 除外キーワードを追加</button>

        <details class="collapsible" id="userSection">
          <summary class="collapsible-summary">
            <span class="collapsible-summary-text">ユーザー・ハッシュタグ</span>
            <button type="button" class="clear-btn" data-clear="user">クリア</button>
          </summary>
          <div class="user-grid">
            <div class="input-group">
              <label for="from">from:</label>
              <input type="text" id="from" placeholder="ユーザー名" />
            </div>
            <div class="input-group">
              <label for="to">to:</label>
              <input type="text" id="to" placeholder="宛先" />
            </div>
            <div class="input-group">
              <label for="mention">@:</label>
              <input type="text" id="mention" placeholder="メンション" />
            </div>
            <div class="input-group">
              <label for="hashtag">#:</label>
              <input type="text" id="hashtag" placeholder="ハッシュタグ" />
            </div>
          </div>
        </details>

        <details class="collapsible" id="mediaFilterSection">
          <summary class="collapsible-summary">
            <span class="collapsible-summary-text">メディア・フィルター</span>
            <button type="button" class="clear-btn" data-clear="media">クリア</button>
          </summary>
          <div class="checkbox-grid">
            <label><input type="checkbox" id="filterLinks" /> リンク</label>
            <label><input type="checkbox" id="filterMedia" /> メディア</label>
            <label><input type="checkbox" id="filterImages" /> 画像</label>
            <label><input type="checkbox" id="filterVideos" /> 動画</label>
            <label><input type="checkbox" id="filterRetweets" /> リツイート</label>
            <label><input type="checkbox" id="filterReplies" /> リプライ</label>
            <label><input type="checkbox" id="filterQuote" /> 引用ツイート</label>
          </div>
        </details>

        <details class="collapsible" id="dateSection">
          <summary class="collapsible-summary">
            <span class="collapsible-summary-text">日付範囲</span>
            <button type="button" class="clear-btn" data-clear="date">クリア</button>
          </summary>
          <div class="date-grid">
            <div class="input-group">
              <label for="since">開始</label>
              <input type="date" id="since" />
            </div>
            <div class="input-group">
              <label for="until">終了</label>
              <input type="date" id="until" />
            </div>
          </div>
        </details>

        <details class="collapsible" id="engagementSection">
          <summary class="collapsible-summary">
            <span class="collapsible-summary-text">エンゲージメント・言語</span>
            <button type="button" class="clear-btn" data-clear="engagement">クリア</button>
          </summary>
          <div class="engagement-grid">
            <div class="input-group">
              <label for="minRetweets">RT数以上</label>
              <input type="number" id="minRetweets" min="0" placeholder="0" />
            </div>
            <div class="input-group">
              <label for="minFaves">いいね数以上</label>
              <input type="number" id="minFaves" min="0" placeholder="0" />
            </div>
            <div class="input-group">
              <label for="minReplies">リプライ数以上</label>
              <input type="number" id="minReplies" min="0" placeholder="0" />
            </div>
            <div class="input-group">
              <label for="lang">言語</label>
              <select id="lang">
                <option value="">指定なし</option>
                <option value="ja">日本語</option>
                <option value="en">英語</option>
                <option value="ko">韓国語</option>
                <option value="zh">中国語</option>
              </select>
            </div>
          </div>
        </details>

        <section class="tool-section preview-section">
          <h2>生成クエリ（プレビュー）</h2>
          <div id="preview" class="preview-box">クエリがここに表示されます</div>
          <button type="button" id="copyBtn" class="primary-btn" disabled>📋 コピー</button>
          <p id="copyStatus" class="status-message"></p>
        </section>
      </div>

      <button type="button" id="searchBtn" class="floating-btn primary-btn">
        <svg class="x-logo" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.451-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>
        <span>で検索を開く</span>
      </button>

      <section class="usage-section">
        <h2>注意事項</h2>
        <ul>
          <li>このツールはブラウザ上で動作し、データはサーバーに送信されません</li>
          <li>直近の検索条件は cookie に保存され、リフレッシュ時に復元されます</li>
          <li>X の検索オペレーターは Web 仕様により一部動作が異なる場合があります</li>
        </ul>
      </section>

      <section class="usage-section">
        <h2>このツールでできること</h2>
        <p>
          X の検索は、慣れると <code>from:</code> や <code>filter:</code> といった演算子を組み合わせて、かなり細かく絞り込める。ただし書式を覚えるのが面倒で、毎回手で打つと打ち間違いも出る。このツールはフォームを埋めるだけで正しい検索クエリを組み立て、そのまま X の検索結果を開くところまでをまとめている。
        </p>
        <p>
          作ったクエリはプレビューに表示されるので、どんな演算子に変換されたのかを見て覚える、という使い方もできる。
        </p>
      </section>

      <section class="usage-section">
        <h2>主な検索演算子の早見表</h2>
        <p>フォームの各項目は、最終的に次のような演算子に変換される。手打ちするときの参考にもなる。</p>
        <ul>
          <li><code>from:ユーザー名</code> … そのユーザーの投稿だけ</li>
          <li><code>to:ユーザー名</code> … そのユーザー宛ての返信</li>
          <li><code>since:2026-01-01</code> / <code>until:2026-03-31</code> … 期間で絞る</li>
          <li><code>filter:images</code> / <code>filter:videos</code> … 画像・動画付きだけ</li>
          <li><code>min_faves:100</code> / <code>min_retweets:50</code> … いいね・RTの下限</li>
          <li><code>lang:ja</code> … 言語で絞る</li>
          <li><code>-語句</code> … その語句を含む投稿を除外</li>
        </ul>
      </section>

      <section class="usage-section">
        <h2>利用上の注意</h2>
        <p>
          検索の挙動は X 側の仕様変更で変わることがあり、ここで挙げた演算子が一部効かなくなる場合もある。閲覧は X 上で各自の利用規約の範囲で行うものとして、このツールはあくまで検索URLを組み立てる補助に徹している。
        </p>
      </section>

      <section class="usage-section">
        <h2>よくある質問</h2>
        <dl class="faq-list">
          <dt>X で画像付きツイートだけを検索する方法は？</dt>
          <dd>「メディア・フィルター」を展開して「画像」にチェックを入れ、検索を実行すると、画像付きの投稿だけが表示される。</dd>
          <dt>X で特定のユーザーの投稿だけを検索する方法は？</dt>
          <dd>「ユーザー・ハッシュタグ」を展開し、from 欄にユーザー名を入れて検索すると、そのユーザーの投稿だけに絞れる。</dd>
          <dt>このツールは無料ですか？</dt>
          <dd>無料。ブラウザ上で動作し、入力した条件をサーバーへ送ることもない。</dd>
        </dl>
      </section>
    </article>

    <ArticleFooterNav currentHref="/tools/x-search-builder/" currentTags={currentTags} backHref="/tools/" backLabel="← ツール一覧に戻る" />
</ArticleLayout>

<script>
  const COOKIE_NAME = 'x-search-builder-state';
  const COOKIE_PATH = '/tools/x-search-builder/';
  const COOKIE_DAYS = 30;

  function getFormData() {
    const keywords: string[] = [];
    document.querySelectorAll<HTMLInputElement>('.keyword-input').forEach((el) => {
      const v = el.value.trim();
      if (v) keywords.push(v);
    });
    const excludes: string[] = [];
    document.querySelectorAll<HTMLInputElement>('.exclude-input').forEach((el) => {
      const v = el.value.trim();
      if (v) excludes.push(v);
    });
    return {
      keywords,
      excludes,
      from: (document.getElementById('from') as HTMLInputElement)?.value?.trim() || '',
      to: (document.getElementById('to') as HTMLInputElement)?.value?.trim() || '',
      mention: (document.getElementById('mention') as HTMLInputElement)?.value?.trim() || '',
      hashtag: (document.getElementById('hashtag') as HTMLInputElement)?.value?.trim() || '',
      filterLinks: (document.getElementById('filterLinks') as HTMLInputElement)?.checked || false,
      filterMedia: (document.getElementById('filterMedia') as HTMLInputElement)?.checked || false,
      filterImages: (document.getElementById('filterImages') as HTMLInputElement)?.checked || false,
      filterVideos: (document.getElementById('filterVideos') as HTMLInputElement)?.checked || false,
      filterRetweets: (document.getElementById('filterRetweets') as HTMLInputElement)?.checked || false,
      filterReplies: (document.getElementById('filterReplies') as HTMLInputElement)?.checked || false,
      filterQuote: (document.getElementById('filterQuote') as HTMLInputElement)?.checked || false,
      since: (document.getElementById('since') as HTMLInputElement)?.value || '',
      until: (document.getElementById('until') as HTMLInputElement)?.value || '',
      minRetweets: (document.getElementById('minRetweets') as HTMLInputElement)?.value || '',
      minFaves: (document.getElementById('minFaves') as HTMLInputElement)?.value || '',
      minReplies: (document.getElementById('minReplies') as HTMLInputElement)?.value || '',
      lang: (document.getElementById('lang') as HTMLSelectElement)?.value || '',
    };
  }

  function buildQuery(data: ReturnType<typeof getFormData>): string {
    const parts: string[] = [];
    if (data.keywords.length > 0) {
      parts.push(data.keywords.map((k) => `"""${k}"""`).join(' AND '));
    }
    if (data.from) parts.push(`from:${data.from.replace(/^@/, '')}`);
    if (data.to) parts.push(`to:${data.to.replace(/^@/, '')}`);
    if (data.mention) parts.push(`@${data.mention.replace(/^@/, '')}`);
    if (data.hashtag) parts.push(data.hashtag.startsWith('#') ? data.hashtag : `#${data.hashtag}`);
    if (data.filterLinks) parts.push('filter:links');
    if (data.filterMedia) parts.push('filter:media');
    if (data.filterImages) parts.push('filter:images');
    if (data.filterVideos) parts.push('filter:videos');
    if (data.filterRetweets) parts.push('filter:retweets');
    if (data.filterReplies) parts.push('filter:replies');
    if (data.filterQuote) parts.push('filter:quote');
    if (data.since) parts.push(`since:${data.since}`);
    if (data.until) parts.push(`until:${data.until}`);
    if (data.minRetweets) parts.push(`min_retweets:${data.minRetweets}`);
    if (data.minFaves) parts.push(`min_faves:${data.minFaves}`);
    if (data.minReplies) parts.push(`min_replies:${data.minReplies}`);
    (data.excludes || []).forEach((e) => {
      parts.push(e.includes(' ') ? `-"${e}"` : `-${e}`);
    });
    if (data.lang) parts.push(`lang:${data.lang}`);
    return parts.join(' ');
  }

  function updatePreview() {
    const data = getFormData();
    const query = buildQuery(data);
    const preview = document.getElementById('preview');
    const copyBtn = document.getElementById('copyBtn') as HTMLButtonElement;
    if (preview) {
      preview.textContent = query || 'クエリがここに表示されます';
      preview.style.color = query ? 'var(--color-text)' : 'var(--color-text-muted)';
      preview.style.fontStyle = query ? 'normal' : 'italic';
    }
    if (copyBtn) copyBtn.disabled = !query;
  }

  function setCookie(value: string) {
    const expires = new Date();
    expires.setTime(expires.getTime() + COOKIE_DAYS * 24 * 60 * 60 * 1000);
    document.cookie = `${COOKIE_NAME}=${encodeURIComponent(value)}; path=${COOKIE_PATH}; expires=${expires.toUTCString()}; SameSite=Lax`;
  }

  function getCookie(): string | null {
    const match = document.cookie.match(new RegExp(`(?:^|; )${COOKIE_NAME}=([^;]*)`));
    return match ? decodeURIComponent(match[1]) : null;
  }

  function restoreForm(data: ReturnType<typeof getFormData>) {
    const container = document.getElementById('keywordInputs');
    if (!container) return;
    container.innerHTML = '';
    const kw = data.keywords.length > 0 ? data.keywords : [''];
    kw.forEach((v, i) => {
      const row = document.createElement('div');
      row.className = 'keyword-row';
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'keyword-input';
      input.dataset.keyword = '';
      input.placeholder = '検索語句';
      input.value = v;
      row.appendChild(input);
      if (i > 0) {
        const delBtn = document.createElement('button');
        delBtn.type = 'button';
        delBtn.className = 'del-btn';
        delBtn.textContent = '削除';
        delBtn.addEventListener('click', () => {
          row.remove();
          updatePreview();
        });
        row.appendChild(delBtn);
      }
      input.addEventListener('input', updatePreview);
      container.appendChild(row);
    });
    const excludeSection = document.getElementById('excludeSection');
    const excludeInputs = document.getElementById('excludeInputs');
    if (excludeSection && excludeInputs) {
      const ex: string[] = data.excludes?.length ? data.excludes : ('exclude' in data && typeof (data as { exclude?: string }).exclude === 'string' ? [(data as { exclude: string }).exclude] : []);
      if (ex.length > 0) {
        excludeSection.hidden = false;
        excludeInputs.innerHTML = '';
        ex.forEach((v) => {
          const row = document.createElement('div');
          row.className = 'exclude-row';
          const input = document.createElement('input');
          input.type = 'text';
          input.className = 'exclude-input';
          input.placeholder = '除外したい語句';
          input.value = v;
          row.appendChild(input);
          const delBtn = document.createElement('button');
          delBtn.type = 'button';
          delBtn.className = 'exclude-del-btn';
          delBtn.textContent = '削除';
          delBtn.addEventListener('click', () => {
            row.remove();
            if (excludeInputs.querySelectorAll('.exclude-row').length === 0) excludeSection.hidden = true;
            updatePreview();
          });
          row.appendChild(delBtn);
          input.addEventListener('input', updatePreview);
          excludeInputs.appendChild(row);
        });
      }
    }
    (document.getElementById('from') as HTMLInputElement).value = data.from;
    (document.getElementById('to') as HTMLInputElement).value = data.to;
    (document.getElementById('mention') as HTMLInputElement).value = data.mention;
    (document.getElementById('hashtag') as HTMLInputElement).value = data.hashtag;
    (document.getElementById('filterLinks') as HTMLInputElement).checked = data.filterLinks;
    (document.getElementById('filterMedia') as HTMLInputElement).checked = data.filterMedia;
    (document.getElementById('filterImages') as HTMLInputElement).checked = data.filterImages;
    (document.getElementById('filterVideos') as HTMLInputElement).checked = data.filterVideos;
    (document.getElementById('filterRetweets') as HTMLInputElement).checked = data.filterRetweets;
    (document.getElementById('filterReplies') as HTMLInputElement).checked = data.filterReplies;
    (document.getElementById('filterQuote') as HTMLInputElement).checked = data.filterQuote;
    (document.getElementById('since') as HTMLInputElement).value = data.since;
    (document.getElementById('until') as HTMLInputElement).value = data.until;
    (document.getElementById('minRetweets') as HTMLInputElement).value = data.minRetweets;
    (document.getElementById('minFaves') as HTMLInputElement).value = data.minFaves;
    (document.getElementById('minReplies') as HTMLInputElement).value = data.minReplies;
    (document.getElementById('lang') as HTMLSelectElement).value = data.lang;

    // 保存済みの選択がある折りたたみセクションは展開する
    const userSection = document.getElementById('userSection') as HTMLDetailsElement;
    if (userSection && (data.from || data.to || data.mention || data.hashtag)) userSection.open = true;
    const mediaSection = document.getElementById('mediaFilterSection') as HTMLDetailsElement;
    if (mediaSection && (data.filterLinks || data.filterMedia || data.filterImages || data.filterVideos || data.filterRetweets || data.filterReplies || data.filterQuote)) mediaSection.open = true;
    const dateSection = document.getElementById('dateSection') as HTMLDetailsElement;
    if (dateSection && (data.since || data.until)) dateSection.open = true;
    const engagementSection = document.getElementById('engagementSection') as HTMLDetailsElement;
    if (engagementSection && (data.minRetweets || data.minFaves || data.minReplies || data.lang)) engagementSection.open = true;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const saved = getCookie();
    if (saved) {
      try {
        const data = JSON.parse(saved);
        restoreForm(data);
      } catch (_e) {
        /* ignore */
      }
    } else {
      document.querySelectorAll<HTMLInputElement>('.keyword-input').forEach((el) => {
        el.addEventListener('input', updatePreview);
      });
    }

    document.getElementById('from')?.addEventListener('input', updatePreview);
    document.getElementById('to')?.addEventListener('input', updatePreview);
    document.getElementById('mention')?.addEventListener('input', updatePreview);
    document.getElementById('hashtag')?.addEventListener('input', updatePreview);
    ['filterLinks', 'filterMedia', 'filterImages', 'filterVideos', 'filterRetweets', 'filterReplies', 'filterQuote'].forEach((id) => {
      document.getElementById(id)?.addEventListener('change', updatePreview);
    });
    document.getElementById('since')?.addEventListener('input', updatePreview);
    document.getElementById('until')?.addEventListener('input', updatePreview);
    document.getElementById('minRetweets')?.addEventListener('input', updatePreview);
    document.getElementById('minFaves')?.addEventListener('input', updatePreview);
    document.getElementById('minReplies')?.addEventListener('input', updatePreview);
    document.getElementById('lang')?.addEventListener('change', updatePreview);

    document.querySelectorAll('.clear-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const target = (btn as HTMLButtonElement).dataset.clear;
        if (target === 'user') {
          (document.getElementById('from') as HTMLInputElement).value = '';
          (document.getElementById('to') as HTMLInputElement).value = '';
          (document.getElementById('mention') as HTMLInputElement).value = '';
          (document.getElementById('hashtag') as HTMLInputElement).value = '';
        } else if (target === 'media') {
          ['filterLinks', 'filterMedia', 'filterImages', 'filterVideos', 'filterRetweets', 'filterReplies', 'filterQuote'].forEach((id) => {
            (document.getElementById(id) as HTMLInputElement).checked = false;
          });
        } else if (target === 'date') {
          (document.getElementById('since') as HTMLInputElement).value = '';
          (document.getElementById('until') as HTMLInputElement).value = '';
        } else if (target === 'engagement') {
          (document.getElementById('minRetweets') as HTMLInputElement).value = '';
          (document.getElementById('minFaves') as HTMLInputElement).value = '';
          (document.getElementById('minReplies') as HTMLInputElement).value = '';
          (document.getElementById('lang') as HTMLSelectElement).value = '';
        }
        updatePreview();
      });
    });

    const infoBtn = document.getElementById('keywordInfoBtn');
    const infoTooltip = document.getElementById('keywordInfoTooltip');
    if (infoBtn && infoTooltip) {
      infoBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !infoTooltip.hidden;
        infoTooltip.hidden = isOpen;
        infoBtn.setAttribute('aria-expanded', String(!isOpen));
      });
      document.addEventListener('click', () => {
        infoTooltip.hidden = true;
        infoBtn.setAttribute('aria-expanded', 'false');
      });
    }

    document.getElementById('addExcludeBtn')?.addEventListener('click', () => {
      const section = document.getElementById('excludeSection');
      const container = document.getElementById('excludeInputs');
      if (!section || !container) return;
      section.hidden = false;
      const row = document.createElement('div');
      row.className = 'exclude-row';
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'exclude-input';
      input.placeholder = '除外したい語句';
      row.appendChild(input);
      const delBtn = document.createElement('button');
      delBtn.type = 'button';
      delBtn.className = 'exclude-del-btn';
      delBtn.textContent = '削除';
      delBtn.addEventListener('click', () => {
        row.remove();
        if (container.querySelectorAll('.exclude-row').length === 0) section.hidden = true;
        updatePreview();
      });
      row.appendChild(delBtn);
      input.addEventListener('input', updatePreview);
      container.appendChild(row);
      input.focus();
    });

    document.getElementById('addKeywordBtn')?.addEventListener('click', () => {
      const container = document.getElementById('keywordInputs');
      if (!container) return;
      const row = document.createElement('div');
      row.className = 'keyword-row';
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'keyword-input';
      input.dataset.keyword = '';
      input.placeholder = '検索語句';
      row.appendChild(input);
      const delBtn = document.createElement('button');
      delBtn.type = 'button';
      delBtn.className = 'del-btn';
      delBtn.textContent = '削除';
      delBtn.addEventListener('click', () => {
        row.remove();
        updatePreview();
      });
      row.appendChild(delBtn);
      input.addEventListener('input', updatePreview);
      container.appendChild(row);
      input.focus();
    });

    document.getElementById('copyBtn')?.addEventListener('click', async () => {
      const query = buildQuery(getFormData());
      if (!query) return;
      try {
        await navigator.clipboard.writeText(query);
        const status = document.getElementById('copyStatus');
        if (status) {
          status.textContent = '✅ クリップボードにコピーしました！';
          status.style.color = 'var(--color-success)';
          setTimeout(() => { status.textContent = ''; }, 3000);
        }
      } catch (_err) {
        alert('クリップボードへのコピーに失敗しました');
      }
    });

    document.getElementById('searchBtn')?.addEventListener('click', () => {
      const data = getFormData();
      const query = buildQuery(data);
      if (!query.trim()) {
        alert('検索条件を入力してください');
        return;
      }
      setCookie(JSON.stringify(data));
      window.open(`https://x.com/search?q=${encodeURIComponent(query)}`, '_blank');
    });

    const searchBtn = document.getElementById('searchBtn');
    let scrollTicking = false;
    function checkFloatingButtonVisibility() {
      if (!searchBtn) return;
      const scrollTop = window.scrollY ?? document.documentElement.scrollTop;
      const scrollHeight = document.documentElement.scrollHeight;
      const clientHeight = document.documentElement.clientHeight;
      const threshold = 80;
      const isAtBottom = scrollTop + clientHeight >= scrollHeight - threshold;
      if (isAtBottom) {
        searchBtn.classList.add('floating-btn-hidden');
      } else {
        searchBtn.classList.remove('floating-btn-hidden');
      }
    }
    window.addEventListener('scroll', () => {
      if (!scrollTicking) {
        requestAnimationFrame(() => {
          checkFloatingButtonVisibility();
          scrollTicking = false;
        });
        scrollTicking = true;
      }
    }, { passive: true });
    checkFloatingButtonVisibility();

    updatePreview();
  });
</script>

