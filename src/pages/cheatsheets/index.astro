---
import Layout from '../../layouts/Layout.astro';
import { itemList } from '../../utils/jsonLd';

const cheatsheets = [
  { name: 'Gitコマンドチートシート', url: '/cheatsheets/git-cheatsheet/', desc: '初期設定、ブランチ・マージ、リモート操作、履歴の書き換えなど、基礎から応用まで5編構成で網羅。' },
  { name: 'Dockerコマンドチートシート', url: '/cheatsheets/docker-cheatsheet/', desc: '基本操作、イメージ管理、コンテナ操作、Docker Compose、Tips まで、実務で使うコマンドを整理。' },
  { name: 'SQL基本コマンド集', url: '/cheatsheets/sql-cheatsheet/', desc: 'SELECT の基礎、JOIN・サブクエリ、データ操作、ウィンドウ関数まで。MySQL/PostgreSQL 対応。' },
];
const items = cheatsheets.map((c) => ({ name: c.name, url: c.url }));
const jsonLd = itemList('チートシート', 'Git・Docker・SQL のコマンドリファレンス集。基礎から応用まで、実務でよく使うコマンドをカテゴリ別に整理しています。', 'https://hrstsh.com/cheatsheets', items);
---

<Layout title="チートシート - hrの備忘録" description="Git・Docker・SQL のコマンドリファレンス集。基礎から応用まで、実務でよく使うコマンドをカテゴリ別に整理しています。" jsonLd={jsonLd}>
  <main>
    <header class="page-header">
      <h1>チートシート</h1>
      <p class="subtitle">よく使うコマンドのリファレンス集</p>
    </header>

    <section class="intro-section">
      <p>
        Git・Docker・SQL を使っていると、たまにしか打たないコマンドやオプションをつい忘れる。そのたびに検索し直すのが地味に面倒なので、自分がよく使うものを手元のメモ代わりにまとめたのがこのチートシートです。
      </p>
      <p>
        各シートは「基礎 → 応用」の順に並べていて、コマンドにはどんなときに使うかの一言を添えてあります。コピーしてそのまま打てる形で載せているので、思い出したいコマンドを探す目的でも、ひととおり眺めて使える技を増やす目的でも使えます。
      </p>
    </section>

    <ul class="post-list">
      {cheatsheets.map((sheet) => (
        <li>
          <a class="post-row" href={sheet.url}>
            <span class="post-title">{sheet.name}</span>
            <span class="post-desc">{sheet.desc}</span>
          </a>
        </li>
      ))}
    </ul>

    <footer class="page-footer">
      <a href="/">トップに戻る</a>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    color: var(--color-text);
  }

  .subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .intro-section {
    margin-bottom: 2.5rem;
  }

  .intro-section p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .intro-section p:last-child {
    margin-bottom: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-row {
    display: block;
    padding: 1.4rem 0.75rem;
    margin-inline: -0.75rem;
    border-bottom: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast);
  }

  .post-row:hover {
    background: rgba(102, 126, 234, 0.04);
  }

  .post-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.7;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .post-row:hover .post-title {
    color: var(--color-primary);
  }

  .post-desc {
    display: block;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-top: 0.55rem;
  }

  .page-footer {
    margin-top: 2.5rem;
    text-align: center;
  }

  .page-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .page-footer a:hover {
    color: var(--color-accent);
  }
</style>
